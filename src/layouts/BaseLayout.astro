---
import '../styles/global.css';
import { WHATSAPP_NUMBER, EMAIL_ADDRESS, PHONE_TEL, LOCATIONS } from '../data/site.ts';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  showFaq?: boolean;
}

const { 
  title = "LEGEND INDUSTRIES | Bulk Bag Manufacturing & Corporate Gifting — Hyderabad",
  description = "Hyderabad-based bag manufacturing since 1998. Custom bags, jute & cotton eco bags, corporate gifting. Bulk orders, custom branding, PAN India supply. Built for reliability.",
  noindex = false,
  showFaq = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// JSON-LD Schemas
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "LEGEND INDUSTRIES",
  description: "Hyderabad-based bag manufacturing and corporate gifting company established in 1998. Specializing in bulk bag production, custom branding, and PAN India supply.",
  foundingDate: "1998",
  url: "https://legendindustry.in",
  logo: {
    "@type": "ImageObject",
    url: "https://legendindustry.in/og-image.jpg",
    width: 1200,
    height: 630,
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Hyderabad",
    addressRegion: "Telangana",
    addressCountry: "IN",
  },
  telephone: PHONE_TEL,
  email: EMAIL_ADDRESS,
  sameAs: [
    `https://wa.me/${WHATSAPP_NUMBER}`,
    ...LOCATIONS.map(loc => loc.mapsUrl)
  ],
  areaServed: {
    "@type": "Country",
    name: "India",
  },
  serviceType: [
    "Bag Manufacturing",
    "Corporate Gifting",
    "Custom Branding",
    "Bulk Production",
  ],
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "LEGEND INDUSTRIES",
  description: "Bulk bag manufacturing and corporate gifting. Custom bags, jute & cotton eco bags, corporate products. PAN India supply from Hyderabad.",
  foundingDate: "1998",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Hyderabad",
    addressRegion: "Telangana",
    addressCountry: "IN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "17.3850",
    longitude: "78.4867",
  },
  telephone: PHONE_TEL,
  email: EMAIL_ADDRESS,
  hasMap: LOCATIONS[0].mapsUrl,
  priceRange: "$$",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      opens: "09:00",
      closes: "22:00"
    }
  ],
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "LEGEND INDUSTRIES",
  url: "https://legendindustry.in",
  description: description,
  inLanguage: "en-IN",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is the minimum order quantity?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "We specialize in bulk orders. Typical minimums start around 100 units, but this varies by product. Contact us with your specific requirements for an accurate quote.",
      },
    },
    {
      "@type": "Question",
      name: "What is the typical production and delivery timeline?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Production typically takes 1–3 weeks depending on order size and customization complexity. Delivery timelines are discussed during the order process.",
      },
    },
    {
      "@type": "Question",
      name: "What products do you manufacture?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "We manufacture custom bags (travel, duffle, laptop, school, drawstring), jute and cotton eco bags, corporate gifting items, and utility products like water bottles — all with custom branding options.",
      },
    },
    {
      "@type": "Question",
      name: "Do you supply PAN India?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, we supply across India. Our production facility is based in Hyderabad, Telangana, and we deliver to clients PAN India.",
      },
    },
    {
      "@type": "Question",
      name: "Can you customize products with your company logo?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, customization is our core strength. We offer logo printing, custom sizes, material selection, color combinations, and custom packaging for bulk orders.",
      },
    },
    {
      "@type": "Question",
      name: "What materials do you use for bag manufacturing?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "We work with a variety of materials including canvas, nylon, polyester, jute, cotton, and leatherette. Material selection depends on your requirements, budget, and intended use case.",
      },
    },
    {
      "@type": "Question",
      name: "Do you provide samples before bulk production?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, we provide design mockups and samples for custom orders. Sample approval is required before production begins to ensure the final product meets your expectations.",
      },
    },
    {
      "@type": "Question",
      name: "What is your pricing structure?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pricing depends on product type, quantity, materials, and customization requirements. We offer competitive pricing for bulk orders. Share your requirements for a detailed quote.",
      },
    },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Custom Bags & Corporate Gifts",
  description: "Bulk manufacturing of custom bags including travel, duffle, laptop, school bags, and corporate gifting items with custom branding.",
  brand: {
    "@type": "Brand",
    name: "LEGEND INDUSTRIES",
  },
  manufacturer: {
    "@type": "Organization",
    name: "LEGEND INDUSTRIES",
  },
  category: "Bag Manufacturing & Corporate Gifting",
  offers: {
    "@type": "Offer",
    priceCurrency: "INR",
    availability: "https://schema.org/InStock",
    url: "https://legendindustry.in/capabilities",
  },
};

const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "SpeakableSpecification",
  cssSelector: ["h1", ".description-text", ".faq-answer"],
  xpath: ["//h1", "//p[contains(@class, 'description')]", "//dd"],
};

const geoSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  name: "Hyderabad, Telangana",
  description: "Manufacturing facility location for LEGEND INDUSTRIES",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Hyderabad",
    addressRegion: "Telangana",
    addressCountry: "IN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "17.3850",
    longitude: "78.4867",
  },
};

function getBreadcrumbSchema(urlPath: string) {
  const pathParts = urlPath.split('/').filter(Boolean);
  if (pathParts.length === 0) return null;

  const items = [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://legendindustry.in/",
    },
  ];
  
  let currentPath = '';
  pathParts.forEach((part, index) => {
    currentPath += `/${part}`;
    items.push({
      "@type": "ListItem",
      position: index + 2,
      name: part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
      item: `https://legendindustry.in${currentPath}`,
    });
  });
  
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items,
  };
}

const currentPath = Astro.url.pathname;
const breadcrumbSchema = getBreadcrumbSchema(currentPath);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#c2410c" />
    
    <!-- Self-hosted Inter font (Latin subset) -->
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" hreflang="en-IN" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={canonicalURL} />
      </>
    )}
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:site_name" content="LEGEND INDUSTRIES" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://legendindustry.in/og-image.jpg" />
    <meta property="og:image:alt" content="LEGEND INDUSTRIES — Custom Bags & Corporate Gifting, Hyderabad" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://legendindustry.in/og-image.jpg" />
    
    <!-- Google Bot -->
    <meta name="googlebot" content="index, follow" />
    <meta name="googlebot" content="max-video-preview:-1" />
    <meta name="googlebot" content="max-image-preview:large" />
    <meta name="googlebot" content="max-snippet:-1" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(geoSchema)} />
    {showFaq && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>