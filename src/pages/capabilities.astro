---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Icon from '../components/Icons.astro';
import { BAG_TYPES, ECO_TYPES, CORPORATE_TYPES, UTILITY_TYPES, CUSTOMIZATION_OPTIONS } from '../data/site';

const title = "Capabilities | LEGEND INDUSTRIES";
const description = "Bulk manufacturing partner for custom bags, eco bags, corporate kits, and utility merchandise with full branding and packaging support.";

const capabilityStats = [
  { value: "40+", label: "Product formats" },
  { value: "4", label: "Core categories" },
  { value: "PAN India", label: "Supply footprint" },
  { value: "1–3 Weeks", label: "Typical dispatch window" },
] as const;

const productGroups = [
  {
    id: 'bags',
    label: 'Category 01',
    title: 'Custom Bags',
    icon: 'backpack' as const,
    tone: 'bg-brand-50 text-brand-600',
    description:
      'From daily carry to large-capacity travel options, we develop purpose-driven bags for branding, utility, and long-term use.',
    items: BAG_TYPES,
  },
  {
    id: 'eco',
    label: 'Category 02',
    title: 'Eco Bags (Jute & Cotton)',
    icon: 'leaf' as const,
    tone: 'bg-green-50 text-green-600',
    description:
      'Sustainable product lines for conscious brands, retail promotions, and CSR-led initiatives.',
    items: ECO_TYPES,
  },
  {
    id: 'corporate',
    label: 'Category 03',
    title: 'Corporate Gifting',
    icon: 'gift' as const,
    tone: 'bg-purple-50 text-purple-600',
    description:
      'Premium and practical corporate combinations curated for employee onboarding, events, and dealer engagement.',
    items: CORPORATE_TYPES,
  },
  {
    id: 'utility',
    label: 'Category 04',
    title: 'Utility Merchandise',
    icon: 'droplet' as const,
    tone: 'bg-blue-50 text-blue-600',
    description:
      'High-usage merchandise that keeps your brand visible in everyday environments.',
    items: UTILITY_TYPES,
  },
] as const;

const industryUseCases = [
  'Corporate onboarding and employee welcome kits',
  'Trade shows, conferences, and offline events',
  'Dealer/distributor loyalty and incentive programs',
  'Institutional and education procurement',
  'Retail and eCommerce promotional bundles',
  'Seasonal campaign and festive gifting',
] as const;

const engagementModels = [
  {
    title: 'Build from Scratch',
    desc: 'We co-develop the structure, dimensions, material mix, branding placement, and packaging for your exact use case.',
  },
  {
    title: 'Standard + Brand Adaptation',
    desc: 'Select from proven formats and customize with logo, colorways, and finishing for faster turnaround.',
  },
  {
    title: 'Category Mix Orders',
    desc: 'Combine bags, utility items, and gifting products into one coordinated production plan and dispatch schedule.',
  },
] as const;
---

<BaseLayout title={title} description={description}>
  <Header />

  <main id="main-content">
    <section aria-labelledby="cap-hero" class="relative overflow-hidden bg-neutral-900 text-white">
      <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
        <div class="h-full w-full bg-[radial-gradient(circle_at_top_right,_rgba(34,197,94,0.3),_transparent_45%),radial-gradient(circle_at_20%_80%,_rgba(249,115,22,0.25),_transparent_40%)]"></div>
      </div>
      <div class="container-site section-padding relative z-10">
        <span class="inline-block text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-brand-400 mb-5">
          Products • Manufacturing • Customization
        </span>
        <h1 id="cap-hero" class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-6 max-w-4xl">
          A Wider Product Range for <span class="text-brand-400">Serious Bulk Requirements</span>
        </h1>
        <p class="text-lg text-neutral-300 leading-relaxed max-w-3xl mb-10">
          LEGEND INDUSTRIES supports high-volume branded procurement with a deeper catalogue across custom bags, eco alternatives,
          corporate kits, and utility products — built for consistency, repeat orders, and business outcomes.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
          {capabilityStats.map((stat) => (
            <div class="rounded-xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
              <p class="text-2xl font-bold text-white mb-1">{stat.value}</p>
              <p class="text-sm text-neutral-300">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="portfolio-heading" class="section-padding">
      <div class="container-site">
        <SectionHeader
          label="Capability Portfolio"
          title="Explore Our Full Product Spectrum"
          description="Each category is production-ready for wholesale and corporate volumes, with flexible customization depth based on your timeline and budget."
        />

        <div class="grid lg:grid-cols-2 gap-6 lg:gap-8">
          {productGroups.map((group) => (
            <article id={group.id} class="card border border-neutral-200/70">
              <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 mb-2">{group.label}</p>
                  <h2 class="text-2xl font-bold text-neutral-900">{group.title}</h2>
                </div>
                <div class={`w-14 h-14 rounded-xl flex items-center justify-center ${group.tone}`}>
                  <Icon name={group.icon} />
                </div>
              </div>

              <p class="text-sm text-neutral-600 leading-relaxed mb-5">{group.description}</p>

              <ul class="grid sm:grid-cols-2 gap-3">
                {group.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-neutral-700">
                    <Icon name="check" class="text-brand-500 shrink-0 mt-0.5" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="custom-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader
          label="Customization Layer"
          title="How We Adapt Products to Your Brand"
          description="Most orders are custom-built. We align execution details with your branding guidelines, quality expectations, and intended audience."
        />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {CUSTOMIZATION_OPTIONS.map((item) => (
            <div class="card">
              <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand-500 flex items-center justify-center mb-4">
                <Icon name={item.icon} />
              </div>
              <h3 class="font-bold text-neutral-900 mb-2">{item.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="fit-heading" class="section-padding">
      <div class="container-site">
        <div class="grid lg:grid-cols-5 gap-8 items-start">
          <div class="lg:col-span-2">
            <SectionHeader
              label="Where It Fits"
              title="Use Cases We Support"
              description="We design around how products will be distributed, used, and perceived in real business settings."
            />
          </div>
          <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
            {industryUseCases.map((item) => (
              <div class="rounded-xl border border-neutral-200 bg-white px-4 py-4 flex items-start gap-2">
                <Icon name="checkSquare" class="text-brand-500 shrink-0 mt-0.5" />
                <p class="text-sm text-neutral-700 leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="order-types-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader label="Engagement Models" title="Ways to Place Bulk Orders" align="center" />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {engagementModels.map((item) => (
            <article class="card text-center">
              <h3 class="font-bold text-neutral-900 mb-3">{item.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{item.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="cap-cta" class="section-padding bg-neutral-900 text-white">
      <div class="container-site text-center">
        <h2 id="cap-cta" class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Need a Custom Product Mix?</h2>
        <p class="text-neutral-400 text-lg mb-8 max-w-2xl mx-auto">
          Share your target quantity, preferred categories, and branding requirements. We&apos;ll help you structure the right production plan.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <WhatsAppButton
            message="Hi, I'd like to discuss a bulk order. Here are my requirements:\n\nCategories: \nQuantity: \nCustomization needed: \nExpected delivery date: "
            label="Discuss Your Requirement"
            size="lg"
          />
          <a href="/process" class="btn-outline border-neutral-600 text-white hover:border-brand-400 hover:text-brand-400">
            See How Orders Work <Icon name="arrowRight" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
