---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Icon from '../components/Icons.astro';
import { CLIENT_TYPES, WHY_CHOOSE } from '../data/site';

const title = "Company | LEGEND INDUSTRIES";
const description = "LEGEND INDUSTRIES — Hyderabad-based bag manufacturing since 1998. Dedicated production unit for bulk bag manufacturing and corporate supply. PAN India delivery.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main id="main-content">
    <section aria-labelledby="company-hero" class="bg-neutral-900 text-white">
      <div class="container-site section-padding">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-brand-400 mb-4">About Us</span>
        <h1 id="company-hero" class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-6">
          LEGEND <span class="text-brand-400">INDUSTRIES</span>
        </h1>
        <p class="text-lg text-neutral-300 leading-relaxed max-w-2xl">
          Hyderabad-based bag manufacturing and corporate gifting company established in 1998. Built for execution and finished with care.
        </p>
      </div>
    </section>

    <section aria-labelledby="story-heading" class="section-padding">
      <div class="container-site">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <div>
            <SectionHeader label="Our Story" title="25+ Years of Reliable Manufacturing" />
            <div class="space-y-4 text-neutral-600 leading-relaxed">
              <p>LEGEND INDUSTRIES was established in 1998 in Hyderabad, Telangana. Our focus has been on bulk bag manufacturing and corporate supply.</p>
              <p>We operate a dedicated production unit designed for medium to large quantity orders. Our infrastructure, processes, and team are built around reliable production, consistent quality, and on-time delivery.</p>
              <p>Over the years, we have worked with corporate clients, distributors, institutions, and marketing agencies across India. Our focus remains on execution quality and building long-term business relationships.</p>
            </div>
          </div>
          <dl class="grid grid-cols-2 gap-4">
            {[
              { value: "1998", label: "Established" },
              { value: "25+", label: "Years Active" },
              { value: "PAN", label: "India Supply" },
              { value: "100%", label: "Bulk Focus" },
            ].map((stat) => (
              <div class="card text-center">
                <dt class="text-3xl font-bold text-brand-500 mb-1">{stat.value}</dt>
                <dd class="text-xs text-neutral-500 uppercase tracking-wider">{stat.label}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <section aria-labelledby="clients-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader label="Our Clients" title="Who We Work With" description="We typically work with businesses requiring consistent supply, corporate clients with branding needs, and distributors handling volume sales." align="center" />
        <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {CLIENT_TYPES.map((item) => (
            <div class="card">
              <h3 class="font-bold text-neutral-900 mb-2">{item.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="why-heading" class="section-padding">
      <div class="container-site">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <div>
            <SectionHeader label="Our Strength" title="Why Businesses Choose Us" />
            <ul class="space-y-3">
              {WHY_CHOOSE.map((item) => (
                <li class="flex items-start gap-3 text-sm text-neutral-700">
                  <Icon name="check" class="text-brand-500 shrink-0 mt-0.5" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <TestimonialCard
            quote="Vast variety to choose from — Impeccable Quality at a very reasonable Pricing. Delivered at a Short notice. Thanks. Genuinely recommended."
            name="Dr. Khizer Hussain Junaidy"
            subtitle="Director of Caspian Healthcare, Hyderabad."
          />
        </div>
      </div>
    </section>

    <section aria-labelledby="ops-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader label="Operations" title="Production & Delivery" align="center" />
        <div class="grid sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { title: "Production Capacity", desc: "Structured for medium to large quantity orders. Consistent capacity aligned for bulk and repeat business." },
            { title: "Quality Checks", desc: "Streamlined quality inspection at multiple stages — raw material, production, and pre-dispatch." },
            { title: "Delivery", desc: "1–3 week typical timeline. PAN India delivery. Committed timelines discussed and confirmed during order process." },
          ].map((item) => (
            <div class="card text-center">
              <h3 class="font-bold text-neutral-900 mb-2">{item.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section aria-labelledby="company-cta" class="section-padding bg-neutral-900 text-white">
      <div class="container-site text-center">
        <h2 id="company-cta" class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Work With Us</h2>
        <p class="text-neutral-400 text-lg mb-8 max-w-xl mx-auto">If you&apos;re looking for long-term supply or bulk production, we&apos;re the right partner.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <WhatsAppButton message="Hi, I'd like to discuss a long-term bulk supply arrangement with LEGEND INDUSTRIES." label="Connect on WhatsApp" size="lg" />
          <a href="/capabilities" class="btn-outline border-neutral-600 text-white hover:border-brand-400 hover:text-brand-400">
            View Our Capabilities <Icon name="arrowRight" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>