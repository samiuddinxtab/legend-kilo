---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InquiryWidget from '../components/InquiryWidget.astro';
import Icon from '../components/Icons.astro';
import { EMAIL_ADDRESS, PHONE_NUMBER, PHONE_TEL, LOCATIONS } from '../data/site';

const title = "Contact | LEGEND INDUSTRIES";
const description = "Contact LEGEND INDUSTRIES for bulk bag manufacturing and corporate gifting. WhatsApp for fastest response. Hyderabad-based, PAN India supply.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main id="main-content">
    <section aria-labelledby="contact-hero-heading" class="bg-neutral-900 text-white">
      <div class="container-site section-padding">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12">
          <div class="max-w-2xl">
            <span class="inline-block text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-brand-300 mb-5">
              Get In Touch
            </span>
            <h1 id="contact-hero-heading" class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-5">
              Let&apos;s talk about<br />
              <span class="text-brand-300">your requirement</span>
            </h1>
            <p class="text-base sm:text-lg text-neutral-300 max-w-md mb-8">
              Bulk bags, custom branding, corporate gifting — we manufacture and ship PAN India.
              WhatsApp is the fastest way to get a quote.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-neutral-100" aria-label="Contact details and inquiry form">
      <div class="container-site">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div aria-label="Contact information">
            <h2 class="text-xl sm:text-2xl font-bold text-neutral-900 mb-5">Reach us directly</h2>

            <div class="flex flex-col gap-2.5 mb-7">
              <a
                href="https://wa.me/919052088880?text=Hi%2C%20I%20need%20bulk%20bags%20for%20my%20business.%20Can%20you%20help%3F"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3.5 p-4 bg-[var(--color-wa-green)]/10 border border-[var(--color-wa-green)]/30 rounded-xl text-inherit no-underline hover:border-[var(--color-wa-green)] hover:shadow-md transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-[var(--color-wa-green)]/15 text-[var(--color-wa-green)] flex items-center justify-center shrink-0">
                  <Icon name="whatsapp" size={22} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">WhatsApp</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{PHONE_NUMBER}</span>
                  <span class="block text-xs text-neutral-500">Fastest response · tap to open</span>
                </div>
                <Icon name="arrowRight" class="w-4 h-4 text-neutral-400 shrink-0" size={16} />
              </a>

              <a
                href={`tel:${PHONE_TEL}`}
                class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="phone" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Phone</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{PHONE_NUMBER}</span>
                  <span class="block text-xs text-neutral-500">Mon – Sat, 10:30 AM – 10 PM</span>
                </div>
              </a>

              <a
                href={`mailto:${EMAIL_ADDRESS}`}
                class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="mail" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Email</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{EMAIL_ADDRESS}</span>
                  <span class="block text-xs text-neutral-500">For formal RFQs and documents</span>
                </div>
              </a>

              <div class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="mapPin" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Location</span>
                  <span class="block text-sm font-semibold text-neutral-900">Hyderabad, Telangana</span>
                  <span class="block text-xs text-neutral-500">Office + Factory · PAN India supply</span>
                </div>
              </div>
            </div>

            {LOCATIONS && LOCATIONS.length > 0 && (
              <div class="border-t border-neutral-200 pt-6">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">Our locations</h3>
                <div class="flex flex-col gap-2">
                  {LOCATIONS.map((location) => (
                    <a
                      href={location.mapsUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-start gap-3 p-3.5 bg-white border border-neutral-200 rounded-lg text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
                    >
                      <div class="w-2 h-2 rounded-full bg-brand-500 shrink-0 mt-1.5" aria-hidden="true"></div>
                      <div class="flex-1 min-w-0">
                        <span class="block text-sm font-semibold text-neutral-900 mb-0.5">{location.name}</span>
                        <span class="block text-xs text-neutral-500 leading-relaxed">{location.address}</span>
                      </div>
                      <Icon name="arrowRight" class="w-3.5 h-3.5 text-neutral-400 shrink-0 mt-0.5" size={14} />
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <div class="lg:sticky lg:top-6 order-first lg:order-none">
            <InquiryWidget />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
