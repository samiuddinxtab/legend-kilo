---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InquiryWidget from '../components/InquiryWidget.astro';
import Icon from '../components/Icons.astro';
import { EMAIL_ADDRESS, PHONE_NUMBER, PHONE_TEL, WHATSAPP_NUMBER, LOCATIONS } from '../data/site';

const title = "Contact | LEGEND INDUSTRIES";
const description = "Contact LEGEND INDUSTRIES for bulk bag manufacturing and corporate gifting. WhatsApp for fastest response. Hyderabad-based, PAN India supply.";

const waHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent("Hi, I need bulk bags for my business. Can you help?")}`;
---

<BaseLayout title={title} description={description}>
  <Header />

  <main id="main-content">
    <section aria-labelledby="contact-hero-heading" class="bg-neutral-900 text-white">
      <div class="container-site section-padding">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12">
          <div class="max-w-2xl">
            <span class="inline-block text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-brand-500 mb-5">
              Get In Touch
            </span>
            <h1 id="contact-hero-heading" class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-5">
              Let&apos;s talk about<br />
              <span class="text-brand-500">your requirement</span>
            </h1>
            <p class="text-base sm:text-lg text-neutral-300 max-w-md mb-8">
              Bulk bags, custom branding, corporate gifting — we manufacture and ship PAN India.
              WhatsApp is the fastest way to get a quote.
            </p>

            <div class="flex flex-wrap items-center gap-3">
              <a
                href={waHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 min-h-[52px] bg-[var(--color-wa-green)] text-white font-semibold rounded-xl hover:bg-[var(--color-wa-green-hover)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-wa-green)] transition-colors text-base"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp Now
              </a>
              <a
                href={PHONE_TEL}
                class="inline-flex items-center gap-2 px-5 py-3 min-h-[52px] border border-white/20 text-neutral-200 font-medium rounded-xl hover:border-white/40 hover:text-white hover:bg-white/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-colors text-base"
              >
                <Icon name="phone" size={18} />
                {PHONE_NUMBER}
              </a>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-0 bg-white/5 border border-white/10 rounded-xl p-5 max-w-xl">
            <div class="flex flex-col gap-1 px-6 first:pl-0">
              <span class="text-xl font-bold text-white">24 hrs</span>
              <span class="text-xs uppercase tracking-wider text-neutral-500 font-medium">Quote turnaround</span>
            </div>
            <div class="h-9 w-px bg-white/10 shrink-0" aria-hidden="true"></div>
            <div class="flex flex-col gap-1 px-6">
              <span class="text-xl font-bold text-white">PAN India</span>
              <span class="text-xs uppercase tracking-wider text-neutral-500 font-medium">Delivery coverage</span>
            </div>
            <div class="h-9 w-px bg-white/10 shrink-0" aria-hidden="true"></div>
            <div class="flex flex-col gap-1 px-6 last:pr-0">
              <span class="text-xl font-bold text-white">MOQ 100</span>
              <span class="text-xs uppercase tracking-wider text-neutral-500 font-medium">Minimum order</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-neutral-100" aria-label="Contact details and inquiry form">
      <div class="container-site">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div aria-label="Contact information">
            <h2 class="text-xl sm:text-2xl font-bold text-neutral-900 mb-5">Reach us directly</h2>

            <div class="flex flex-col gap-2.5 mb-7">
              <a
                href={waHref}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3.5 p-4 bg-green-50 border border-green-200 rounded-xl text-inherit no-underline hover:border-[var(--color-wa-green)] hover:shadow-md transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-green-100 text-green-600 flex items-center justify-center shrink-0">
                  <Icon name="whatsapp" size={22} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">WhatsApp</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{PHONE_NUMBER}</span>
                  <span class="block text-xs text-neutral-500">Fastest response · tap to open</span>
                </div>
                <Icon name="arrowRight" class="w-4 h-4 text-neutral-400 shrink-0" size={16} />
              </a>

              <a
                href={PHONE_TEL}
                class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="phone" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Phone</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{PHONE_NUMBER}</span>
                  <span class="block text-xs text-neutral-500">Mon – Sat, 10:30 AM – 10 PM</span>
                </div>
              </a>

              <a
                href={`mailto:${EMAIL_ADDRESS}`}
                class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
              >
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="mail" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Email</span>
                  <span class="block text-sm font-semibold text-neutral-900 truncate">{EMAIL_ADDRESS}</span>
                  <span class="block text-xs text-neutral-500">For formal RFQs and documents</span>
                </div>
              </a>

              <div class="flex items-center gap-3.5 p-4 bg-white border border-neutral-200 rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-neutral-100 text-neutral-600 flex items-center justify-center shrink-0">
                  <Icon name="mapPin" size={20} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-wider text-neutral-500">Location</span>
                  <span class="block text-sm font-semibold text-neutral-900">Hyderabad, Telangana</span>
                  <span class="block text-xs text-neutral-500">Office + Factory · PAN India supply</span>
                </div>
              </div>
            </div>

            {LOCATIONS && LOCATIONS.length > 0 && (
              <div class="border-t border-neutral-200 pt-6">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">Our locations</h3>
                <div class="flex flex-col gap-2">
                  {LOCATIONS.map((location) => (
                    <a
                      href={location.mapsUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-start gap-3 p-3.5 bg-white border border-neutral-200 rounded-lg text-inherit no-underline hover:border-brand-500 hover:shadow-sm transition-colors"
                    >
                      <div class="w-2 h-2 rounded-full bg-brand-500 shrink-0 mt-1.5" aria-hidden="true"></div>
                      <div class="flex-1 min-w-0">
                        <span class="block text-sm font-semibold text-neutral-900 mb-0.5">{location.name}</span>
                        <span class="block text-xs text-neutral-500 leading-relaxed">{location.address}</span>
                      </div>
                      <Icon name="arrowRight" class="w-3.5 h-3.5 text-neutral-400 shrink-0 mt-0.5" size={14} />
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <div class="lg:sticky lg:top-6">
            <InquiryWidget />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
