---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Icon from '../components/Icons.astro';
import { CAPABILITIES, QUALIFICATION_POINTS, NOT_A_FIT, FAQS } from '../data/site';
---

<BaseLayout showFaq={true}>
  <Header />

  <main id="main-content">
    {/* Hero */}
    <section aria-labelledby="hero-heading" class="bg-neutral-900 text-white">
      <div class="container-site section-padding">
        <div class="max-w-3xl">
          <span class="inline-block text-sm font-semibold tracking-widest uppercase text-brand-300 mb-4">
            Bag Manufacturing &middot; Since 1998
          </span>
          <h1 id="hero-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-6">
            Custom Bags & Corporate Products,{" "}
            <span class="text-brand-300">Built for Business.</span>
          </h1>
          <p class="text-lg sm:text-xl text-neutral-300 leading-relaxed mb-8 max-w-2xl">
            LEGEND INDUSTRIES manufactures custom bags and offers tailored gifting solution.
            Full customization, reliable delivery, PAN India
            supply.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/capabilities" class="btn-primary">
              View Capabilities
              <Icon name="arrowRight" />
            </a>
          </div>
        </div>
        <div class="mt-8 rounded-xl border border-brand-200 bg-white p-5 sm:p-6 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold text-neutral-900">Do you have any requirement?</p>
            <p class="text-sm text-neutral-600">Send your category + quantity now to receive MOQ and pricing guidance.</p>
          </div>
          <WhatsAppButton
            message="Hi, we have a requirement. Please help us with MOQ, pricing slabs, and delivery timeline."
            label="Share Requirement on WhatsApp"
          />
        </div>
      </div>
    </section>

    {/* Capabilities Overview */}
    <section aria-labelledby="capabilities-heading" class="section-padding">
      <div class="container-site">
        <SectionHeader
          label="What We Do"
          title="Manufacturing That Delivers"
          description="Custom bags, corporate gifting, and utility products — all produced in bulk with full branding support."
        />
        <div class="grid sm:grid-cols-2 gap-6">
          {CAPABILITIES.map((item) => (
            <article class="card">
              <div class="w-14 h-14 rounded-xl bg-brand-50 text-brand-500 flex items-center justify-center mb-5">
                {item.icon === 'factory' && <Icon name="factory" />}
                {item.icon === 'palette' && <Icon name="palette" />}
                {item.icon === 'truck' && <Icon name="truck" />}
                {item.icon === 'shield' && <Icon name="shield" />}
              </div>
              <h3 class="text-lg font-bold text-neutral-900 mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed">
                {item.desc}
              </p>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/capabilities" class="btn-outline">
            View All Capabilities
            <Icon name="arrowRight" />
          </a>
        </div>
      </div>
    </section>

    {/* Process Preview */}
    <section aria-labelledby="process-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader
          label="How It Works"
          title="Simple, Structured Process"
          description="No confusion. Share your requirement, we handle the rest."
          align="center"
          id="process-heading"
        />
        <ol class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6 list-none p-0 m-0">
          {[
            { step: "01", title: "Share Requirement", desc: "You share product type, quantity and branding needs." },
            { step: "02", title: "Discuss Options", desc: "We review and discuss material, design, and pricing." },
            { step: "03", title: "Sample / Approval", desc: "Design and sample approval before production." },
            { step: "04", title: "Production", desc: "Quality-controlled manufacturing begins." },
            { step: "05", title: "Delivery", desc: "Dispatched within committed timeline." },
          ].map((item, index) => (
            <li class="text-center relative">
              <div
                class="w-12 h-12 rounded-full bg-brand-500 text-white font-bold text-sm flex items-center justify-center mx-auto mb-4"
                aria-hidden="true"
              >
                {item.step}
              </div>
              <h3 class="font-semibold text-neutral-900 mb-1">
                <span class="sr-only">Step {item.step}: </span>
                {item.title}
              </h3>
              <p class="text-xs text-neutral-600 leading-relaxed">
                {item.desc}
              </p>
              {index < 4 && (
                <div class="hidden lg:block mt-4" aria-hidden="true">
                  <Icon name="arrowRight" class="text-neutral-300 mx-auto" size={24} />
                </div>
              )}
            </li>
          ))}
        </ol>
        <div class="mt-10 text-center">
          <a href="/process" class="btn-outline">
            View Full Process
            <Icon name="arrowRight" />
          </a>
        </div>
      </div>
    </section>

    {/* Credibility */}
    <section aria-labelledby="credibility-heading" class="section-padding">
      <div class="container-site">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="section-label">Since 1998</span>
            <h2 id="credibility-heading" class="section-title mt-3 mb-4">
              25+ Years of Reliable Manufacturing
            </h2>
            <p class="text-neutral-600 leading-relaxed mb-6">
              LEGEND INDUSTRIES has been producing bags and corporate products
              from Hyderabad since 1998. Our focus has always been on
              execution quality, reliable timelines, and building long-term
              business relationships.
            </p>
            <dl class="grid grid-cols-3 gap-6 mb-8">
              {[
                { value: "25+", label: "Years" },
                { value: "PAN", label: "India Supply" },
                { value: "100%", label: "Custom Focus" },
              ].map((stat) => (
                <div class="text-center">
                  <dt class="text-2xl sm:text-3xl font-bold text-brand-500">
                    {stat.value}
                  </dt>
                  <dd class="text-xs text-neutral-500 mt-1 uppercase tracking-wider">
                    {stat.label}
                  </dd>
                </div>
              ))}
            </dl>
            <a href="/company" class="btn-outline">
              Learn More About Us
              <Icon name="arrowRight" />
            </a>
          </div>
          <TestimonialCard
            quote="Vast variety to choose from — Impeccable Quality at a very reasonable Pricing. Delivered at a Short notice. Thanks. Genuinely recommended."
            name="Dr. Khizer Hussain Junaidy"
            subtitle="Director of Caspian Healthcare, Hyderabad."
          />
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section aria-labelledby="faq-heading" class="section-padding bg-neutral-100">
      <div class="container-site">
        <SectionHeader
          label="Common Questions"
          title="Frequently Asked"
          align="center"
        />
        <div class="max-w-3xl mx-auto space-y-4">
          {FAQS.map((faq) => (
            <details
              class="group bg-white rounded-xl border border-neutral-200 overflow-hidden"
            >
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-semibold text-neutral-900 hover:text-brand-500 transition-colors min-h-12">
                {faq.q}
                <Icon name="chevronDown" class="text-neutral-400 group-open:rotate-180 transition-transform shrink-0" />
              </summary>
              <div class="px-6 pb-4 text-sm text-neutral-600 leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section aria-labelledby="cta-heading" class="section-padding bg-neutral-900 text-white">
      <div class="container-site text-center">
        <h2 id="cta-heading" class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight mb-4">
          Ready to Discuss Your Requirement?
        </h2>
        <p class="text-neutral-400 text-lg mb-8 max-w-xl mx-auto">
          Share your product needs, quantity, and branding requirements. We
          respond within business hours.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <WhatsAppButton
            message="Hi, I'd like to discuss a custom bags / corporate gifting order from LEGEND INDUSTRIES."
            label="Chat on WhatsApp"
            size="lg"
          />
          <a href="/contact" class="btn-outline-dark border-neutral-600 text-white hover:border-[var(--color-wa-green)] hover:text-[var(--color-wa-green)]">
            View All Contact Options
            <Icon name="arrowRight" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>