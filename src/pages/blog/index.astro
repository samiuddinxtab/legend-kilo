---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Icon from '../../components/Icons.astro';
import BlogCard from '../../components/BlogCard.astro';
import { BLOG_ARTICLES } from '../../data/site';

const title = "Blog | LEGEND INDUSTRIES";
const description = "B2B insights on bulk bag suppliers in Hyderabad, custom corporate gifting in India, and MOQ planning for bag manufacturing.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main id="main-content">
    <section aria-labelledby="blog-hero" class="bg-neutral-900 text-white">
      <div class="container-site section-padding">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-brand-400 mb-4">Insights & Resources</span>
        <h1 id="blog-hero" class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-6">
          Practical B2B <span class="text-brand-400">Buying Guides</span>
        </h1>
        <p class="text-lg text-neutral-300 leading-relaxed max-w-3xl mb-8">
          No stock photos, no fluff. Just procurement-focused content for teams evaluating bulk bag suppliers in Hyderabad,
          custom corporate gifting partners in India, and MOQ-led manufacturing decisions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#articles-heading" class="btn-primary">
            Browse Articles <Icon name="arrowRight" />
          </a>
          <WhatsAppButton
            message="Hi, we need guidance for a bulk bag / corporate gifting requirement. Please help us shortlist the right category and MOQ."
            label="Talk to an Expert"
          />
        </div>
      </div>
    </section>

    <section aria-labelledby="articles-heading" class="section-padding">
      <div class="container-site">
        <SectionHeader
          label="SEO Knowledge Hub"
          title="Latest Manufacturing & Gifting Articles"
          description="This library is editable from one data source and intentionally image-free for speed, clarity, and production readiness."
        />

        <h2 id="articles-heading" class="sr-only">Blog Articles</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {BLOG_ARTICLES.map((article) => (
            <BlogCard
              title={article.title}
              description={article.description}
              slug={article.slug}
              datePublished={article.datePublished}
              keywords={article.keywords}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-neutral-100">
      <div class="container-site">
        <div class="card bg-white text-center max-w-3xl mx-auto">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-600 mb-2">Need tailored recommendations?</p>
          <h2 class="text-2xl font-bold text-neutral-900 mb-3">Get Category + MOQ Guidance in One Call</h2>
          <p class="text-neutral-600 mb-6">
            Share your use case and target quantity. We&apos;ll recommend the right product mix, customization route, and realistic timeline.
          </p>
          <WhatsAppButton
            message="Hi, we need B2B guidance for category selection, MOQ, and timeline."
            label="Start on WhatsApp"
            size="lg"
          />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
