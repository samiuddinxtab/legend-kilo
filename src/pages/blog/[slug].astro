---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Icon from '../../components/Icons.astro';
import { BLOG_ARTICLES } from '../../data/site';

type Article = {
  slug: string;
  title: string;
  description: string;
  content: string;
  date: string;
  datePublished: string;
  author: string;
  keywords: string[];
};

// Slug generation: each article has an explicit `slug` field in blog-articles.json.
// getStaticPaths maps article.slug directly to the URL param.
// Blog index links use the same article.slug field — no derivation, no transformation.
// Both sides use the same source of truth, so slugs are always consistent.
export function getStaticPaths() {
  if (!BLOG_ARTICLES || BLOG_ARTICLES.length === 0) return [];
  return BLOG_ARTICLES.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props as { article: Article };

const title = `${article.title} | LEGEND INDUSTRIES Blog`;
const description = article.description || '';
const articleUrl = `https://legendindustry.in/blog/${article.slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: article.title,
  description: article.description,
  articleBody: article.content,
  datePublished: article.datePublished || article.date,
  dateModified: article.datePublished || article.date,
  image: "https://legendindustry.in/og-image.jpg",
  keywords: Array.isArray(article.keywords) ? article.keywords.join(', ') : '',
  author: {
    "@type": "Person",
    name: article.author,
  },
  publisher: {
    "@type": "Organization",
    name: "LEGEND INDUSTRIES",
    url: "https://legendindustry.in",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl,
  },
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <Header />

  <main id="main-content">
    <article class="section-padding">
      <div class="container-site max-w-3xl">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-neutral-500">
            <li><a href="/" class="hover:text-brand-500">Home</a></li>
            <li><span aria-hidden="true">/</span></li>
            <li><a href="/blog" class="hover:text-brand-500">Blog</a></li>
            <li><span aria-hidden="true">/</span></li>
            <li class="text-neutral-900 font-medium truncate max-w-[200px] sm:max-w-none">{article.title}</li>
          </ol>
        </nav>

        <header class="mb-8 border-b border-neutral-200 pb-6">
          <time class="text-sm text-neutral-500 uppercase tracking-wider">
            {new Date(article.datePublished || article.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-neutral-900 mt-2 mb-4">{article.title}</h1>
          <p class="text-lg text-neutral-600 leading-relaxed mb-4">{article.description}</p>
          <div class="flex flex-wrap items-center gap-2 text-sm text-neutral-500">
            <Icon name="user" size={16} />
            <span>{article.author}</span>
            {article.keywords?.length > 0 && (
              <>
                <span class="text-neutral-300">•</span>
                <span>{article.keywords[0]}</span>
              </>
            )}
          </div>
        </header>

        <div class="prose prose-neutral max-w-none">
          {article.content.split('\n\n').map((paragraph: string) => (
            <p class="mb-6 text-neutral-700 leading-relaxed">{paragraph}</p>
          ))}
        </div>

        <aside class="mt-10 rounded-xl border border-neutral-200 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-brand-600 mb-2">Related Search Terms</p>
          <div class="flex flex-wrap gap-2">
            {article.keywords?.map((keyword: string) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-600">{keyword}</span>
            ))}
          </div>
        </aside>

        <div class="mt-12 pt-8 border-t border-neutral-200">
          <div class="card bg-brand-50 border-brand-200">
            <h2 class="text-lg font-bold text-neutral-900 mb-2">Need Practical Guidance for Your Requirement?</h2>
            <p class="text-neutral-600 mb-4">
              Share your category, quantity, and branding goals. We'll help you map MOQ, customization options, and a realistic timeline.
            </p>
            <WhatsAppButton
              message={`Hi, I read your article "${article.title}" and need help with MOQ and product planning for a bulk requirement.`}
              label="Discuss Your Requirement"
            />
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>