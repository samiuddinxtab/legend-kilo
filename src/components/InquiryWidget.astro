---
import WhatsAppButton from './WhatsAppButton.astro';
import Icon from './Icons.astro';
import { PRODUCT_OPTIONS, QUANTITY_OPTIONS, WHATSAPP_NUMBER, EMAIL_ADDRESS } from '../data/site';

export const partial = true;
---

<div class="card" role="form" aria-label="Inquiry form">
  <h3 class="text-xl font-bold text-neutral-900 mb-2">Share Your Requirement</h3>
  <p class="text-sm text-neutral-500 mb-6">
    For faster and accurate quoting, include category, quantity, branding method, and target delivery date.
  </p>

  <div class="space-y-5">
    <div>
      <label for="inquiry-company" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Company / Organization Name <span aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <input id="inquiry-company" type="text" placeholder="e.g. ABC Corp Pvt Ltd" required aria-required="true" autocomplete="organization" class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors" />
    </div>

    <div>
      <label for="inquiry-product" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Product Category <span aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <select id="inquiry-product" required aria-required="true" class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none">
        <option value="">Select a category</option>
        {PRODUCT_OPTIONS.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div>
      <label for="inquiry-quantity" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Approximate Quantity <span aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <select id="inquiry-quantity" required aria-required="true" class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none">
        <option value="">Select quantity range</option>
        {QUANTITY_OPTIONS.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div>
      <label for="inquiry-details" class="block text-sm font-medium text-neutral-700 mb-1.5">Additional Details (optional)</label>
      <textarea id="inquiry-details" placeholder="e.g. Logo type, material preference, delivery city, expected dispatch date" rows={3} class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors resize-none"></textarea>
    </div>
  </div>

  <div class="mt-8 flex flex-col sm:flex-row gap-3">
    <div id="whatsapp-btn-container">
      <WhatsAppButton message="Hi, I'd like to discuss a bulk order with LEGEND INDUSTRIES." label="Send via WhatsApp" class="flex-1" />
    </div>
    <a id="email-btn" href={`mailto:${EMAIL_ADDRESS}?subject=Bulk%20Inquiry`} class="inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-neutral-300 text-neutral-800 font-semibold rounded-lg hover:border-brand-500 hover:text-brand-500 active:bg-neutral-100 transition-all duration-200 min-h-12 flex-1">
      <Icon name="mail" />
      Send via Email
    </a>
  </div>

  <p class="text-xs text-neutral-500 mt-3 text-center" role="status">Required fields: company name, product category, and quantity.</p>
</div>

<script define:vars={{ whatsappNumber: WHATSAPP_NUMBER, emailAddress: EMAIL_ADDRESS }}>
  const companyInput = document.getElementById('inquiry-company');
  const productSelect = document.getElementById('inquiry-product');
  const quantitySelect = document.getElementById('inquiry-quantity');
  const detailsTextarea = document.getElementById('inquiry-details');
  const whatsappBtnContainer = document.getElementById('whatsapp-btn-container');
  const emailBtn = document.getElementById('email-btn');

  function getMessage() {
    const company = companyInput?.value || '';
    const product = productSelect?.value || '';
    const quantity = quantitySelect?.value || '';
    const details = detailsTextarea?.value || '';

    return `Hi LEGEND INDUSTRIES team, I need a bulk manufacturing quote.\n\nCompany: ${company || '[Your Company]'}\nCategory: ${product || '[Product Category]'}\nEstimated Quantity: ${quantity || '[Approx. Quantity]'}\nBranding Required: [Logo print / embroidery / other]\nDelivery Location: [City, State]\nExpected Delivery Date: [DD/MM/YYYY]\nAdditional Details: ${details || '[Any specific requirements]'}\n\nPlease share MOQ, pricing slabs, sampling process, and dispatch timeline.`;
  }

  function isValid() {
    return !!(companyInput?.value.trim() && productSelect?.value && quantitySelect?.value);
  }

  function updateButtons() {
    const valid = isValid();
    const encodedMessage = encodeURIComponent(getMessage());

    if (whatsappBtnContainer) {
      const waLink = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
      const btn = whatsappBtnContainer.querySelector('a');
      if (btn) {
        btn.href = waLink;
        btn.classList.toggle('opacity-50', !valid);
        btn.classList.toggle('pointer-events-none', !valid);
      }
    }

    if (emailBtn) {
      const subject = `Bulk Inquiry — ${productSelect?.value || 'Bag Manufacturing'} | ${companyInput?.value || 'Corporate'}`;
      emailBtn.href = `mailto:${emailAddress}?subject=${encodeURIComponent(subject)}&body=${encodedMessage}`;
      emailBtn.classList.toggle('opacity-50', !valid);
      emailBtn.classList.toggle('pointer-events-none', !valid);
    }
  }

  companyInput?.addEventListener('input', updateButtons);
  productSelect?.addEventListener('change', updateButtons);
  quantitySelect?.addEventListener('change', updateButtons);
  detailsTextarea?.addEventListener('input', updateButtons);

  updateButtons();
</script>
