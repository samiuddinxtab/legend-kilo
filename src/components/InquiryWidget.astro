---
import WhatsAppButton from './WhatsAppButton.astro';
import Icon from './Icons.astro';
import { PRODUCT_OPTIONS, QUANTITY_OPTIONS } from '../data/site';
import { getEmailHref, getDefaultInquiryMessage } from '../utils/links';

export const partial = true;
---

<div class="card" role="form" aria-label="Inquiry form">
  <h3 class="text-xl font-bold text-neutral-900 mb-2">
    Share Your Requirement
  </h3>
  <p class="text-sm text-neutral-500 mb-6">
    Fill in the details below. We&apos;ll send a pre-filled message via
    WhatsApp or email — no forms, no waiting.
  </p>

  <div class="space-y-5">
    <div>
      <label
        for="inquiry-company"
        class="block text-sm font-medium text-neutral-700 mb-1.5"
      >
        Company / Organization Name <span aria-hidden="true">*</span>
        <span class="sr-only">(required)</span>
      </label>
      <input
        id="inquiry-company"
        type="text"
        placeholder="e.g. ABC Corp Pvt Ltd"
        required
        aria-required="true"
        autocomplete="organization"
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors"
      />
    </div>

    <div>
      <label
        for="inquiry-product"
        class="block text-sm font-medium text-neutral-700 mb-1.5"
      >
        Product Category <span aria-hidden="true">*</span>
        <span class="sr-only">(required)</span>
      </label>
      <select
        id="inquiry-product"
        required
        aria-required="true"
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none"
      >
        <option value="">Select a category</option>
        {PRODUCT_OPTIONS.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div>
      <label
        for="inquiry-quantity"
        class="block text-sm font-medium text-neutral-700 mb-1.5"
      >
        Approximate Quantity <span aria-hidden="true">*</span>
        <span class="sr-only">(required)</span>
      </label>
      <select
        id="inquiry-quantity"
        required
        aria-required="true"
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none"
      >
        <option value="">Select quantity range</option>
        {QUANTITY_OPTIONS.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div>
      <label
        for="inquiry-details"
        class="block text-sm font-medium text-neutral-700 mb-1.5"
      >
        Additional Details (optional)
      </label>
      <textarea
        id="inquiry-details"
        placeholder="e.g. Logo printing, specific materials, delivery timeline"
        rows={3}
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors resize-none"
      ></textarea>
    </div>
  </div>

  <div class="mt-8 flex flex-col sm:flex-row gap-3">
    <div id="whatsapp-btn-container">
      <WhatsAppButton
        message="Hi, I'm interested in bulk manufacturing from LEGEND INDUSTRIES. Please share details."
        label="Send via WhatsApp"
        className="flex-1"
      />
    </div>
    <a
      id="email-btn"
      href="mailto:info@legendindustries.in?subject=Bulk%20Inquiry"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-neutral-300 text-neutral-800 font-semibold rounded-lg hover:border-brand-500 hover:text-brand-500 active:bg-neutral-100 transition-all duration-200 min-h-12 flex-1"
    >
      <Icon name="mail" />
      Send via Email
    </a>
  </div>

  <p class="text-xs text-neutral-500 mt-3 text-center" role="status">
    Please fill in company name, product category, and quantity to proceed.
  </p>
</div>

<script>
  const companyInput = document.getElementById('inquiry-company') as HTMLInputElement;
  const productSelect = document.getElementById('inquiry-product') as HTMLSelectElement;
  const quantitySelect = document.getElementById('inquiry-quantity') as HTMLSelectElement;
  const detailsTextarea = document.getElementById('inquiry-details') as HTMLTextAreaElement;
  const whatsappBtnContainer = document.getElementById('whatsapp-btn-container');
  const emailBtn = document.getElementById('email-btn') as HTMLAnchorElement;

  function getMessage(): string {
    const company = companyInput?.value || '';
    const product = productSelect?.value || '';
    const quantity = quantitySelect?.value || '';
    const details = detailsTextarea?.value || '';

    return `Hi, I'm interested in bulk manufacturing from LEGEND INDUSTRIES.

Company: ${company || '[Your Company]'}
Product: ${product || '[Product Category]'}
Quantity: ${quantity || '[Approx. Quantity]'}
Details: ${details || '[Any specific requirements]'}

Please share details on pricing and timelines.`;
  }

  function isValid(): boolean {
    return !!(companyInput?.value.trim() && productSelect?.value && quantitySelect?.value);
  }

  function updateButtons() {
    const valid = isValid();
    const message = getMessage();
    const encodedMessage = encodeURIComponent(message);

    if (whatsappBtnContainer) {
      const waLink = `https://wa.me/919876543210?text=${encodedMessage}`;
      const btn = whatsappBtnContainer.querySelector('a');
      if (btn) {
        btn.href = waLink;
        btn.classList.toggle('opacity-50', !valid);
        btn.classList.toggle('pointer-events-none', !valid);
      }
    }

    if (emailBtn) {
      const subject = `Bulk Inquiry — ${productSelect?.value || 'Bag Manufacturing'} | ${companyInput?.value || 'Corporate'}`;
      const emailHref = `mailto:info@legendindustries.in?subject=${encodeURIComponent(subject)}&body=${encodedMessage}`;
      emailBtn.href = emailHref;
      emailBtn.classList.toggle('opacity-50', !valid);
      emailBtn.classList.toggle('pointer-events-none', !valid);
      emailBtn.classList.toggle('opacity-50', !valid);
    }
  }

  companyInput?.addEventListener('input', updateButtons);
  productSelect?.addEventListener('change', updateButtons);
  quantitySelect?.addEventListener('change', updateButtons);
  detailsTextarea?.addEventListener('input', updateButtons);
</script>