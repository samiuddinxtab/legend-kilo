---
import Icon from './Icons.astro';
import { WHATSAPP_NUMBER, EMAIL_ADDRESS, PHONE_NUMBER, PHONE_TEL, PRODUCT_OPTIONS, QUANTITY_OPTIONS } from '../data/site';
---

<div class="card" role="region" aria-label="Quick inquiry">
  <a
    id="wa-link"
    href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent("Hi, I need bulk bags for my business. Can you help?")}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center gap-2 w-full py-4 px-6 text-lg font-semibold text-white bg-green-600 rounded-lg hover:bg-green-700 active:bg-green-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 transition-colors"
  >
    <Icon name="whatsapp" size={20} />
    Chat on WhatsApp
  </a>

  <div class="flex gap-3 mt-3">
    <a
      href={`tel:${PHONE_TEL}`}
      class="flex-1 flex items-center justify-center gap-2 py-3 px-4 text-sm font-semibold text-neutral-700 bg-neutral-100 rounded-lg hover:bg-neutral-200 active:bg-neutral-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 transition-colors min-h-11"
    >
      <Icon name="phone" size={18} />
      Call
    </a>
    <a
      id="email-link"
      href={`mailto:${EMAIL_ADDRESS}?subject=Bulk%20Order%20Inquiry`}
      class="flex-1 flex items-center justify-center gap-2 py-3 px-4 text-sm font-semibold text-neutral-500 bg-neutral-100 rounded-lg hover:bg-neutral-200 active:bg-neutral-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 transition-colors min-h-11"
    >
      <Icon name="mail" size={18} />
      Email
    </a>
  </div>

  <p class="text-xs text-neutral-500 mt-3 text-center">
    Fastest response on WhatsApp · Usually replies within 2 hours
  </p>

  <div class="flex gap-2 mt-4 flex-wrap" role="group" aria-label="Inquiry type">
    <button
      type="button"
      data-intent="bulk"
      class="intent-pill px-4 py-2 rounded-full text-sm font-medium border border-neutral-300 text-neutral-700 bg-white hover:border-neutral-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 transition-colors min-h-11 active-intent"
    >
      Bulk Order
    </button>
    <button
      type="button"
      data-intent="custom"
      class="intent-pill px-4 py-2 rounded-full text-sm font-medium border border-neutral-300 text-neutral-700 bg-white hover:border-neutral-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 transition-colors min-h-11"
    >
      Custom Design
    </button>
    <button
      type="button"
      data-intent="sample"
      class="intent-pill px-4 py-2 rounded-full text-sm font-medium border border-neutral-300 text-neutral-700 bg-white hover:border-neutral-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 transition-colors min-h-11"
    >
      Sample Request
    </button>
  </div>

  <div class="space-y-3 mt-5">
    <div>
      <label for="iw-name" class="block text-sm font-medium text-neutral-700 mb-1.5">Name</label>
      <input
        id="iw-name"
        type="text"
        placeholder="Your name"
        autocomplete="name"
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors"
      />
    </div>
    <div>
      <label for="iw-phone" class="block text-sm font-medium text-neutral-700 mb-1.5">Phone</label>
      <input
        id="iw-phone"
        type="tel"
        placeholder="Your phone number"
        autocomplete="tel"
        inputmode="tel"
        class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors"
      />
    </div>
  </div>

  <details class="mt-4 group">
    <summary class="text-sm text-neutral-500 cursor-pointer hover:text-neutral-700 transition-colors flex items-center gap-1 select-none">
      <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="m6 9 6 6 6-6" />
      </svg>
      More details (optional)
    </summary>
    <div class="space-y-3 mt-3">
      <div>
        <label for="iw-category" class="block text-sm font-medium text-neutral-700 mb-1.5">Product Category</label>
        <select
          id="iw-category"
          class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none"
        >
          <option value="">Select a category</option>
          {PRODUCT_OPTIONS.map((opt) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
      </div>
      <div>
        <label for="iw-quantity" class="block text-sm font-medium text-neutral-700 mb-1.5">Quantity</label>
        <select
          id="iw-quantity"
          class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors appearance-none"
        >
          <option value="">Select quantity range</option>
          {QUANTITY_OPTIONS.map((opt) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
      </div>
      <div>
        <label for="iw-notes" class="block text-sm font-medium text-neutral-700 mb-1.5">Additional Notes</label>
        <textarea
          id="iw-notes"
          rows={3}
          placeholder="Logo type, material preference, delivery city"
          class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-colors resize-none"
        ></textarea>
      </div>
    </div>
  </details>

  <div class="flex items-center justify-center gap-6 mt-6 pt-4 border-t border-neutral-100 text-xs text-neutral-500">
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
      </svg>
      Quote in 24 hrs
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      WhatsApp support
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      No spam
    </span>
  </div>
</div>

<script define:vars={{ whatsappNumber: WHATSAPP_NUMBER, emailAddress: EMAIL_ADDRESS }}>
  const pills = document.querySelectorAll('.intent-pill');
  const waLink = document.getElementById('wa-link');
  const emailLink = document.getElementById('email-link');
  const nameInput = document.getElementById('iw-name');
  const phoneInput = document.getElementById('iw-phone');
  const categorySelect = document.getElementById('iw-category');
  const quantitySelect = document.getElementById('iw-quantity');
  const notesTextarea = document.getElementById('iw-notes');

  let activeIntent = 'bulk';

  const intentMessages = {
    bulk: 'Hi, I need bulk bags for my business. Can you help?',
    custom: 'Hi, I need custom bags made for my brand. Can you help?',
    sample: 'Hi, I need product samples before placing a bulk order. Can you help?',
  };

  function getFullMessage() {
    let msg = intentMessages[activeIntent] || intentMessages.bulk;

    const name = nameInput?.value.trim() || '';
    const phone = phoneInput?.value.trim() || '';
    const category = categorySelect?.value || '';
    const quantity = quantitySelect?.value || '';
    const notes = notesTextarea?.value.trim() || '';

    if (name || phone || category || quantity || notes) {
      msg += '\n\n';
      if (name) msg += 'Name: ' + name + '\n';
      if (phone) msg += 'Phone: ' + phone + '\n';
      if (category) msg += 'Category: ' + category + '\n';
      if (quantity) msg += 'Quantity: ' + quantity + '\n';
      if (notes) msg += 'Notes: ' + notes + '\n';
    }

    return msg;
  }

  function updateLinks() {
    const msg = getFullMessage();

    if (waLink) {
      waLink.href = 'https://wa.me/' + whatsappNumber + '?text=' + encodeURIComponent(msg);
    }

    if (emailLink) {
      emailLink.href =
        'mailto:' + emailAddress +
        '?subject=' + encodeURIComponent('Inquiry — ' + (categorySelect?.value || 'Bulk Order')) +
        '&body=' + encodeURIComponent(msg);
    }
  }

  pills.forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeIntent = pill.dataset.intent || 'bulk';

      pills.forEach(function (p) {
        p.classList.remove('active-intent', 'bg-brand-500', 'text-white', 'border-brand-500');
      });

      pill.classList.add('active-intent', 'bg-brand-500', 'text-white', 'border-brand-500');
      updateLinks();
    });
  });

  nameInput?.addEventListener('input', updateLinks);
  phoneInput?.addEventListener('input', updateLinks);
  categorySelect?.addEventListener('change', updateLinks);
  quantitySelect?.addEventListener('change', updateLinks);
  notesTextarea?.addEventListener('input', updateLinks);

  const activeBtn = document.querySelector('.intent-pill.active-intent');
  if (activeBtn) {
    activeBtn.classList.add('bg-brand-500', 'text-white', 'border-brand-500');
  }
</script>
