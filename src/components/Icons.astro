---
interface Props {
  name: 'arrowRight' | 'checkCircle' | 'check' | 'xCircle' | 'whatsapp' | 'mail' | 'phone' | 'mapPin' | 'clock' | 'star' | 'chevronDown' | 'menu' | 'close' | 'factory' | 'truck' | 'shield' | 'palette' | 'leaf' | 'gift' | 'droplet' | 'paintbrush' | 'backpack' | 'messageCircle' | 'search' | 'checkSquare' | 'cog';
  class?: string;
  size?: number;
}

const { name, class: className = "", size = 20 } = Astro.props;

const largeIcons = ['factory', 'truck', 'shield', 'palette', 'messageCircle', 'search', 'checkSquare', 'cog'];
const extraLargeIcons = ['leaf', 'gift', 'droplet', 'paintbrush', 'backpack'];

const defaultSize = extraLargeIcons.includes(name) ? 36 : largeIcons.includes(name) ? 32 : name === 'menu' || name === 'close' ? 24 : 20;
const finalSize = size || defaultSize;
---

