---
import Icon from './Icons.astro';

interface Props {
  quote: string;
  name: string;
  subtitle: string;
}

const { quote, name, subtitle } = Astro.props;
---

<figure class="card bg-neutral-900 text-white border-neutral-800">
  <div class="flex items-center gap-1 mb-4" role="img" aria-label="5 out of 5 stars">
    {[...Array(5)].map(() => (
      <Icon name="star" class="text-yellow-400" />
    ))}
  </div>
  <blockquote class="text-neutral-200 leading-relaxed mb-6 text-sm">
    &ldquo;{quote}&rdquo;
  </blockquote>
  <figcaption>
    <div class="font-semibold text-white text-sm">{name}</div>
    <div class="text-neutral-400 text-xs">{subtitle}</div>
  </figcaption>
</figure>